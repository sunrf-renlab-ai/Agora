# Production server env vars. Paste these into the Render dashboard
# (Service → Environment), filling each <placeholder> from the Supabase
# project settings.

# Direct database URL (port 5432). Switch to the pooler URL below if
# you ever move the server to a serverless runtime — the long-lived
# Render dyno is fine with a direct connection.
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# Pooled alternative (recommended if you outgrow the free dyno):
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Signing secret for server-issued tokens. Generate with:
#   openssl rand -base64 48
JWT_SECRET=<32+ character random>

# Public URL of the deployed web app (used by webhooks + email links).
APP_URL=https://<vercel-domain>

# Comma-separated list of origins the server accepts CORS from. With
# the vercel.json proxy the browser only ever hits the Vercel origin,
# so list that here. Add localhost if you hit the Render service
# directly from a dev machine.
ALLOWED_ORIGINS=https://<vercel-domain>

PORT=10000
NODE_ENV=production

# Background workers. Leave as-is unless you're debugging.
AUTOPILOT_SCHEDULER=on
RUNTIME_MONITOR=on
