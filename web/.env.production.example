# Vercel proxies /api/* and /ws through to the Render server (see
# web/vercel.json), so the browser stays on the Vercel origin. These
# env vars must be set in the Vercel dashboard before promoting to prod.

# Public Supabase config (shipped to the client).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>

# Optional: override the API origin if you'd rather hit the Render
# service directly instead of relying on the vercel.json rewrites.
# NEXT_PUBLIC_API_URL=https://agora-server.onrender.com
# NEXT_PUBLIC_WS_URL=wss://agora-server.onrender.com
